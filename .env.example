# --- LLM Provider ---
# "anthropic" or "openai" (openai works for any OpenAI-compatible API)
LLM_PROVIDER=anthropic

# --- API Key ---
LLM_API_KEY=sk-...

# --- Model ---
# Anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514
# OpenAI: gpt-4o, gpt-4o-mini
# Kimi Code: kimi-k2.5
LLM_MODEL=claude-sonnet-4-20250514

# --- Base URL (optional, for non-default endpoints) ---
# Kimi Code:  https://api.kimi.com/coding/  (use anthropic provider)
# OpenAI:     https://api.openai.com/v1
# Any compatible: set provider + base_url
# LLM_BASE_URL=
