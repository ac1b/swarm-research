% neurips_2024.sty — NeurIPS 2024 style (workshop-compatible)
% Based on the official NeurIPS formatting instructions.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/01/01 NeurIPS 2024 Style]

\newif\if@final\@finalfalse
\newif\if@nonatbib\@nonatbibfalse
\newif\if@preprint\@preprintfalse

\DeclareOption{final}{\@finaltrue}
\DeclareOption{nonatbib}{\@nonatbibtrue}
\DeclareOption{preprint}{\@preprinttrue}
\DeclareOption*{\PackageWarning{neurips_2024}{Unknown '\CurrentOption'}}
\ProcessOptions\relax

% ---- Page layout (NeurIPS standard) ----
\RequirePackage[verbose=true,letterpaper]{geometry}
\AtBeginDocument{
  \newgeometry{
    textheight=9in,
    textwidth=5.5in,
    top=1in,
    headheight=12pt,
    headsep=25pt,
    footskip=30pt
  }
}

% ---- Fonts ----
\RequirePackage{times}

% ---- Natbib (optional) ----
\if@nonatbib\else
  \RequirePackage[numbers,sort&compress]{natbib}
\fi

% ---- Title and author ----
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[C]{\thepage}

\def\@maketitle{%
  \newpage
  \null
  \vskip 2em
  \begin{center}%
    {\Large\bfseries \@title \par}%
    \vskip 1.5em%
    {\large
      \lineskip .5em%
      \begin{tabular}[t]{c}%
        \@author
      \end{tabular}\par}%
  \end{center}%
  \par
  \vskip 1.5em%
}

% ---- Sections ----
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}
\titleformat{\paragraph}[runin]{\normalsize\bfseries}{}{0em}{}[.]
\titlespacing{\section}{0pt}{12pt plus 2pt minus 2pt}{4pt plus 1pt minus 1pt}
\titlespacing{\subsection}{0pt}{8pt plus 2pt minus 2pt}{2pt plus 1pt minus 1pt}
\titlespacing{\subsubsection}{0pt}{6pt plus 1pt minus 1pt}{2pt plus 1pt minus 1pt}
\titlespacing{\paragraph}{0pt}{6pt plus 1pt minus 1pt}{6pt}

% ---- Abstract ----
\renewenvironment{abstract}{%
  \centerline{\large\bfseries Abstract}%
  \vspace{0.5ex}%
  \begin{quote}\small
}{%
  \end{quote}%
}

% ---- Footnotes ----
\renewcommand{\footnoterule}{%
  \kern-3pt
  \hrule width 2in height 0.4pt
  \kern 2.6pt
}
\renewcommand{\thefootnote}{\fnsymbol{footnote}}

% ---- Line spacing ----
\renewcommand{\baselinestretch}{1.0}
\setlength{\parskip}{0pt}
\setlength{\parindent}{1em}

% ---- Rules for anonymous / final ----
\if@final
  % Final: show author names
\else
  % Anonymous: could override \author, but we keep it simple
\fi
